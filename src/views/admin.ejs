<%- include('partials/header') %>

<div class="page-header">
  <h1>Administration</h1>
</div>

<% if (success) { %>
  <div class="alert alert-success"><%= success %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="card">
  <h2>Créer un utilisateur</h2>
  <form method="POST" action="/admin/users/create" class="form-inline">
    <div class="form-group">
      <input type="text" name="username" placeholder="Nom d'utilisateur" required minlength="2" maxlength="50">
    </div>
    <div class="form-group">
      <input type="password" name="password" placeholder="Mot de passe" required minlength="4">
    </div>
    <div class="form-group">
      <select name="role">
        <option value="user">Utilisateur</option>
        <option value="admin">Admin</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Créer</button>
  </form>
</div>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
function formatDurationShort(seconds) {
  if (!seconds) return '—';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  if (h > 0) return h + 'h ' + String(m).padStart(2, '0') + 'm';
  return m + 'min';
}
%>

<div class="card">
  <h2>Utilisateurs (<%= users.length %>)</h2>
  <table class="video-table">
    <thead>
      <tr>
        <th>Nom d'utilisateur</th>
        <th>Statut</th>
        <th>Rôle</th>
        <th>Bibliothèques</th>
        <th>Dernière connexion</th>
        <th>Inscrit le</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% for (const u of users) { %>
        <tr<%= u.is_active === 0 ? ' style="opacity:0.5"' : '' %>>
          <td><%= u.username %></td>
          <td>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/toggle-active" style="display:inline">
                <button type="submit" class="btn btn-sm <%= u.is_active ? 'btn-active' : 'btn-danger' %>" style="min-width:70px">
                  <%= u.is_active ? 'Actif' : 'Désactivé' %>
                </button>
              </form>
            <% } else { %>
              <span class="badge badge-success">Actif</span>
            <% } %>
          </td>
          <td>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/role" style="display:inline">
                <select name="role" onchange="this.form.submit()" class="autoplay-select">
                  <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>Utilisateur</option>
                  <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
              </form>
            <% } else { %>
              <span class="badge badge-accent">Admin (vous)</span>
            <% } %>
          </td>
          <td><%= u.library_count %></td>
          <td class="muted"><%= u.last_login_at ? new Date(u.last_login_at).toLocaleString('fr-FR') : 'Jamais' %></td>
          <td class="muted"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
          <td>
            <% if (u.id !== user.id) { %>
              <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
                <form method="POST" action="/admin/users/<%= u.id %>/force-logout" style="display:inline">
                  <button type="submit" class="btn btn-sm" title="Déconnecter l'utilisateur">Déconnecter</button>
                </form>
                <button type="button" class="btn btn-sm" onclick="this.nextElementSibling.style.display='flex'">Mot de passe</button>
                <form method="POST" action="/admin/users/<%= u.id %>/password" style="display:none;gap:0.5rem;align-items:center">
                  <input type="password" name="password" placeholder="Nouveau mot de passe" required style="width:150px;padding:0.3rem 0.5rem;background:var(--bg-primary);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-primary);font-size:0.8rem">
                  <button type="submit" class="btn btn-sm btn-primary">OK</button>
                </form>
                <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline"
                      onsubmit="return confirm('Supprimer le compte de <%= u.username %> ? Toutes ses données seront effacées.')">
                  <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                </form>
              </div>
            <% } %>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Disk usage per library -->
<div class="card">
  <h2>Espace disque par bibliothèque</h2>
  <% if (libStats.length === 0) { %>
    <p class="text-muted">Aucune bibliothèque.</p>
  <% } else { %>
    <table class="video-table">
      <thead>
        <tr>
          <th>Bibliothèque</th>
          <th>Propriétaire</th>
          <th>Vidéos</th>
          <th>Taille</th>
          <th>Durée</th>
        </tr>
      </thead>
      <tbody>
        <% for (const lib of libStats) { %>
          <tr>
            <td><a href="/libraries/<%= lib.id %>" style="color:var(--accent)"><%= lib.name %></a></td>
            <td class="muted"><%= lib.owner %></td>
            <td class="muted"><%= lib.video_count %></td>
            <td><%= formatSize(lib.total_size) %></td>
            <td class="muted"><%= formatDurationShort(lib.total_duration) %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card" style="margin-top: 2rem;">
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
    <h2 style="margin:0;">File d'attente
      <span class="text-muted" style="font-size:0.85rem; font-weight:400; margin-left:0.5rem;">
        <% for (const s of jobStats) { %>
          <span class="badge <%= s.status === 'processing' ? 'badge-accent' : s.status === 'pending' ? 'badge-info' : s.status === 'failed' ? 'badge-danger' : 'badge-success' %>"><%= s.count %> <%= s.status %></span>
        <% } %>
      </span>
    </h2>
    <div style="display:flex;gap:0.5rem;">
      <% const failedCount = jobStats.find(s => s.status === 'failed'); %>
      <% const processingCount = jobStats.find(s => s.status === 'processing'); %>
      <% if (failedCount && failedCount.count > 0) { %>
        <form method="POST" action="/admin/jobs/requeue-failed" style="display:inline">
          <button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Relancer les <%= failedCount.count %> job(s) en erreur ?')">Requeue failed (<%= failedCount.count %>)</button>
        </form>
      <% } %>
      <% if (processingCount && processingCount.count > 0) { %>
        <form method="POST" action="/admin/jobs/requeue-stuck" style="display:inline">
          <button type="submit" class="btn btn-sm" onclick="return confirm('Relancer les jobs bloqués en processing ?')">Requeue stuck</button>
        </form>
      <% } %>
    </div>
  </div>
  <% if (jobs.length === 0) { %>
    <p class="text-muted">Aucun job en attente.</p>
  <% } else { %>
    <table class="video-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Vidéo</th>
          <th>Bibliothèque</th>
          <th>Statut</th>
          <th>Créé</th>
          <th>Erreur</th>
        </tr>
      </thead>
      <tbody>
        <% for (const j of jobs) { %>
          <tr>
            <td class="muted"><%= j.id %></td>
            <td style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= j.filename %>"><%= j.filename %></td>
            <td class="muted" style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= j.library_name %>"><%= j.library_name %></td>
            <td>
              <span class="badge <%= j.status === 'processing' ? 'badge-accent' : j.status === 'pending' ? 'badge-info' : j.status === 'failed' ? 'badge-danger' : 'badge-success' %>"><%= j.status %></span>
            </td>
            <td class="muted"><%= new Date(j.created_at).toLocaleString('fr-FR') %></td>
            <td class="muted" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= j.error || '' %>"><%= j.error || '—' %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card" style="margin-top: 2rem;">
  <h2>Journal d'audit</h2>
  <% if (auditLogs.length === 0) { %>
    <p class="text-muted">Aucune action enregistrée.</p>
  <% } else { %>
    <table class="video-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Admin</th>
          <th>Action</th>
          <th>Détails</th>
        </tr>
      </thead>
      <tbody>
        <% for (const log of auditLogs) { %>
          <tr>
            <td class="muted"><%= new Date(log.created_at).toLocaleString('fr-FR') %></td>
            <td><%= log.admin_username %></td>
            <td>
              <span class="badge <%= log.action === 'delete_user' ? 'badge-danger' : log.action === 'change_role' ? 'badge-accent' : log.action === 'reset_password' ? 'badge-info' : 'badge-success' %>"><%= log.action.replace(/_/g, ' ') %></span>
            </td>
            <td class="muted"><%= log.details || '—' %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('partials/footer') %>
