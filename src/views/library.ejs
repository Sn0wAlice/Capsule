<%- include('partials/header') %>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
function formatDuration(seconds) {
  if (!seconds) return '—';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
  return m + ':' + String(s).padStart(2, '0');
}
const displayMode = typeof listMode !== 'undefined' ? listMode : 'grid';
%>

<div class="page-header">
  <div>
    <h1><%= library.name %></h1>
    <p class="text-muted"><%= library.path %> &mdash; <%= totalVideos %> vidéo(s)
      <% if (permission === 'read') { %>
        <span class="badge badge-info">Lecture seule</span>
      <% } else if (permission === 'write') { %>
        <span class="badge badge-success">Lecture/Écriture</span>
      <% } %>
    </p>
  </div>
  <div class="page-actions">
    <% if (['owner','admin','write'].includes(permission)) { %>
    <form method="POST" action="/libraries/<%= library.id %>/scan" style="display:inline">
      <button type="submit" class="btn btn-sm btn-primary">Scanner</button>
    </form>
    <form method="POST" action="/libraries/<%= library.id %>/reset-previews" style="display:inline"
          onsubmit="return confirm('Supprimer toutes les previews et relancer le traitement ?')">
      <button type="submit" class="btn btn-sm">Regénérer previews</button>
    </form>
    <% } %>
    <button class="btn btn-sm" id="bulk-toggle">Sélectionner</button>
    <a href="/libraries/<%= library.id %>?view=folder" class="btn btn-sm <%= viewMode === 'folder' ? 'btn-active' : '' %>">Dossiers</a>
    <a href="/libraries/<%= library.id %>?view=flat" class="btn btn-sm <%= viewMode === 'flat' ? 'btn-active' : '' %>">Tout</a>
    <% if (viewMode === 'flat') { %>
    <div class="view-toggles">
      <a href="/libraries/<%= library.id %>?view=flat&sort=<%= sort %>&order=<%= order %>&display=grid"
         class="view-toggle-btn <%= displayMode === 'grid' ? 'active' : '' %>" title="Grille">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      </a>
      <a href="/libraries/<%= library.id %>?view=flat&sort=<%= sort %>&order=<%= order %>&display=list"
         class="view-toggle-btn <%= displayMode === 'list' ? 'active' : '' %>" title="Liste">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="4" width="18" height="2" rx="1"/><rect x="3" y="11" width="18" height="2" rx="1"/><rect x="3" y="18" width="18" height="2" rx="1"/></svg>
      </a>
    </div>
    <% } %>
  </div>
</div>

<% if (scanned === 'bg') { %>
  <div class="alert alert-success">Traitement lancé en arrière-plan.</div>
<% } else if (scanned) { %>
  <div class="alert alert-success">Scan terminé : <%= scanned %> fichier(s) trouvé(s)</div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<!-- Scan progress bar -->
<div class="scan-progress" id="scan-progress" style="display:none">
  <div class="scan-progress-info">
    <span id="scan-progress-text">Traitement...</span>
    <span id="scan-progress-count"></span>
  </div>
  <div class="scan-progress-bar">
    <div class="scan-progress-fill" id="scan-progress-fill"></div>
  </div>
</div>

<script>
(function() {
  const el = document.getElementById('scan-progress');
  const text = document.getElementById('scan-progress-text');
  const count = document.getElementById('scan-progress-count');
  const fill = document.getElementById('scan-progress-fill');
  let polling = null;

  function check() {
    fetch('/libraries/<%= library.id %>/progress')
      .then(r => r.json())
      .then(d => {
        if (d.total === 0) { el.style.display = 'none'; return; }
        const pct = d.total > 0 ? Math.round((d.done / d.total) * 100) : 0;
        fill.style.width = pct + '%';
        count.textContent = d.done + ' / ' + d.total;
        if (d.active) {
          el.style.display = '';
          text.textContent = d.processing > 0 ? 'Traitement en cours...' : 'En attente...';
        } else if (d.failed > 0) {
          el.style.display = '';
          text.textContent = 'Terminé (' + d.failed + ' erreur' + (d.failed > 1 ? 's' : '') + ')';
          clearInterval(polling);
        } else {
          el.style.display = '';
          text.textContent = 'Traitement terminé';
          fill.style.width = '100%';
          clearInterval(polling);
          setTimeout(() => { el.style.display = 'none'; }, 5000);
        }
      })
      .catch(() => {});
  }

  check();
  polling = setInterval(check, 3000);
})();
</script>

<% if (viewMode === 'folder') { %>
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/libraries/<%= library.id %>?view=folder">Racine</a>
    <% if (currentPath) {
      const parts = currentPath.split('/');
      let accumulated = '';
      for (let i = 0; i < parts.length; i++) {
        accumulated += (i > 0 ? '/' : '') + parts[i];
    %>
      <span class="separator">/</span>
      <a href="/libraries/<%= library.id %>?view=folder&path=<%= encodeURIComponent(accumulated) %>"><%= parts[i] %></a>
    <% }} %>
  </div>

  <!-- Folders -->
  <% if (folders.length > 0) { %>
    <div class="video-grid">
      <% for (const folder of folders) {
        const folderPath = currentPath ? currentPath + '/' + folder : folder;
      %>
        <a href="/libraries/<%= library.id %>?view=folder&path=<%= encodeURIComponent(folderPath) %>" class="video-card folder-card">
          <div class="video-card-preview folder-card-preview">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div class="video-card-info">
            <span class="video-card-title"><%= folder %></span>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
<% } %>

<% if (viewMode === 'flat') { %>
  <!-- Sort controls (grid mode only) -->
  <% if (displayMode === 'grid') { %>
  <div class="sort-controls">
    Trier par :
    <a href="/libraries/<%= library.id %>?view=flat&sort=name&order=<%= sort === 'name' && order === 'asc' ? 'desc' : 'asc' %>&display=grid"
       class="<%= sort === 'name' ? 'active' : '' %>">
      Nom <%= sort === 'name' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
    </a>
    <a href="/libraries/<%= library.id %>?view=flat&sort=date&order=<%= sort === 'date' && order === 'desc' ? 'asc' : 'desc' %>&display=grid"
       class="<%= sort === 'date' ? 'active' : '' %>">
      Date <%= sort === 'date' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
    </a>
    <a href="/libraries/<%= library.id %>?view=flat&sort=size&order=<%= sort === 'size' && order === 'desc' ? 'asc' : 'desc' %>&display=grid"
       class="<%= sort === 'size' ? 'active' : '' %>">
      Taille <%= sort === 'size' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
    </a>
  </div>
  <% } %>
<% } %>

<!-- Videos -->
<% if (videos.length > 0) { %>
  <% if (displayMode === 'list' && viewMode === 'flat') { %>
    <!-- List View -->
    <table class="video-table">
      <thead>
        <tr>
          <th class="<%= sort === 'name' ? 'sorted' : '' %>">
            <a href="/libraries/<%= library.id %>?view=flat&sort=name&order=<%= sort === 'name' && order === 'asc' ? 'desc' : 'asc' %>&display=list"
               style="color:inherit;text-decoration:none">
              Nom <%= sort === 'name' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
            </a>
          </th>
          <th class="<%= sort === 'size' ? 'sorted' : '' %>">
            <a href="/libraries/<%= library.id %>?view=flat&sort=size&order=<%= sort === 'size' && order === 'desc' ? 'asc' : 'desc' %>&display=list"
               style="color:inherit;text-decoration:none">
              Taille <%= sort === 'size' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
            </a>
          </th>
          <th>Durée</th>
          <th>Vues</th>
          <th class="<%= sort === 'date' ? 'sorted' : '' %>">
            <a href="/libraries/<%= library.id %>?view=flat&sort=date&order=<%= sort === 'date' && order === 'desc' ? 'asc' : 'desc' %>&display=list"
               style="color:inherit;text-decoration:none">
              Date <%= sort === 'date' ? (order === 'asc' ? '&#9650;' : '&#9660;') : '' %>
            </a>
          </th>
        </tr>
      </thead>
      <tbody>
        <% for (const video of videos) { %>
          <tr>
            <td>
              <a href="/videos/<%= video.id %>" class="video-table-link">
                <div class="video-table-thumb">
                  <% if (video.thumb) { %>
                    <img src="/videos/<%= video.id %>/thumb" alt="" loading="lazy">
                  <% } %>
                </div>
                <span class="video-table-name"><%= video.title || video.filename %></span>
              </a>
            </td>
            <td class="muted"><%= formatSize(video.size) %></td>
            <td class="muted"><%= formatDuration(video.duration) %></td>
            <td class="muted"><%= video.view_count || 0 %></td>
            <td class="muted"><%= new Date(video.updated_at || video.created_at).toLocaleDateString('fr-FR') %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  <% } else { %>
    <!-- Grid View -->
    <div class="video-grid" id="video-grid">
      <% for (const video of videos) { %>
        <a href="/videos/<%= video.id %>" class="video-card">
          <div class="video-card-preview">
            <% if (video.thumb) { %>
              <img src="/videos/<%= video.id %>/thumb" alt="" loading="lazy" decoding="async">
            <% } %>
            <% if (video.duration) { %>
              <span class="video-card-duration"><%= formatDuration(video.duration) %></span>
            <% } %>
            <% if (video.view_count > 0) { %>
              <span class="video-card-views"><%= video.view_count %> vue<%= video.view_count > 1 ? 's' : '' %></span>
            <% } %>
          </div>
          <div class="video-card-info">
            <span class="video-card-title"><%= video.title || video.filename %></span>
            <span class="video-card-meta"><%= formatSize(video.size) %></span>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
  <% if (hasMore) { %>
    <div id="load-more" class="load-more">
      <div class="loader"></div>
    </div>
  <% } %>
<% } else if (folders.length === 0) { %>
  <div class="empty-state">
    <p>Aucune vidéo trouvée. Lancez un scan.</p>
  </div>
<% } %>

<% if (viewMode === 'flat' && hasMore) { %>
<script>
(function() {
  const container = document.getElementById('video-grid') || document.querySelector('.video-table tbody');
  const loader = document.getElementById('load-more');
  if (!loader) return;
  const isTable = !document.getElementById('video-grid');
  let page = 2;
  let loading = false;
  let done = false;

  function formatSize(bytes) {
    if (!bytes) return '—';
    const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
    let i = 0; let s = bytes;
    while (s >= 1024 && i < units.length - 1) { s /= 1024; i++; }
    return s.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
  }
  function formatDuration(sec) {
    if (!sec) return '—';
    const h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60), s = Math.floor(sec % 60);
    if (h > 0) return h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    return m + ':' + String(s).padStart(2, '0');
  }

  function loadMore() {
    if (loading || done) return;
    loading = true;
    const params = new URLSearchParams({ page: page, sort: '<%= sort %>', order: '<%= order %>' });
    fetch('/libraries/<%= library.id %>/videos?' + params)
      .then(r => r.json())
      .then(data => {
        for (const v of data.videos) {
          if (isTable) {
            const tr = document.createElement('tr');
            tr.innerHTML =
              '<td><a href="/videos/' + v.id + '" class="video-table-link">' +
              '<div class="video-table-thumb">' + (v.thumb ? '<img src="/videos/' + v.id + '/thumb" alt="" loading="lazy">' : '') + '</div>' +
              '<span class="video-table-name">' + (v.title || v.filename).replace(/</g, '&lt;') + '</span></a></td>' +
              '<td class="muted">' + formatSize(v.size) + '</td>' +
              '<td class="muted">' + formatDuration(v.duration) + '</td>' +
              '<td class="muted">' + (v.view_count || 0) + '</td>' +
              '<td class="muted">' + new Date(v.updated_at || v.created_at).toLocaleDateString('fr-FR') + '</td>';
            container.appendChild(tr);
          } else {
            const card = document.createElement('a');
            card.href = '/videos/' + v.id;
            card.className = 'video-card';
            card.innerHTML =
              '<div class="video-card-preview">' +
              (v.thumb ? '<img src="/videos/' + v.id + '/thumb" alt="" loading="lazy" decoding="async">' : '') +
              (v.duration ? '<span class="video-card-duration">' + formatDuration(v.duration) + '</span>' : '') +
              (v.view_count > 0 ? '<span class="video-card-views">' + v.view_count + ' vue' + (v.view_count > 1 ? 's' : '') + '</span>' : '') +
              '</div><div class="video-card-info">' +
              '<span class="video-card-title">' + (v.title || v.filename).replace(/</g, '&lt;') + '</span>' +
              '<span class="video-card-meta">' + formatSize(v.size) + '</span></div>';
            container.appendChild(card);
          }
        }
        page++;
        loading = false;
        if (!data.hasMore) { done = true; loader.remove(); }
      })
      .catch(() => { loading = false; });
  }

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) loadMore();
  }, { rootMargin: '200px' });
  observer.observe(loader);
})();
</script>
<% } %>

<!-- Bulk action bar (hidden by default) -->
<div class="bulk-bar" id="bulk-bar" style="display:none">
  <div class="bulk-bar-info">
    <span id="bulk-count">0</span> sélectionné(s)
  </div>
  <div class="bulk-bar-actions">
    <button class="btn btn-sm" id="bulk-tag-btn">Tagger</button>
    <button class="btn btn-sm" id="bulk-playlist-btn">Ajouter à playlist</button>
    <% if (['owner','admin','write'].includes(permission)) { %>
      <button class="btn btn-sm btn-danger" id="bulk-delete-btn">Supprimer</button>
    <% } %>
    <button class="btn btn-sm" id="bulk-cancel">Annuler</button>
  </div>
</div>

<script>
(function() {
  const toggleBtn = document.getElementById('bulk-toggle');
  const bar = document.getElementById('bulk-bar');
  const countEl = document.getElementById('bulk-count');
  let bulkMode = false;
  let selected = new Set();

  function updateCount() {
    countEl.textContent = selected.size;
    bar.style.display = selected.size > 0 ? '' : 'none';
  }

  function enterBulkMode() {
    bulkMode = true;
    document.body.classList.add('bulk-mode');
    toggleBtn.textContent = 'Annuler sélection';
    // Add checkboxes to all video cards
    document.querySelectorAll('.video-card:not(.folder-card)').forEach(card => {
      const link = card.getAttribute('href');
      if (!link) return;
      const id = link.split('/videos/')[1];
      if (!id) return;
      card.dataset.videoId = id;
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.className = 'video-card-checkbox';
      cb.dataset.id = id;
      card.prepend(cb);
    });
    // Also handle table rows
    document.querySelectorAll('.video-table-link').forEach(link => {
      const href = link.getAttribute('href');
      if (!href) return;
      const id = href.split('/videos/')[1];
      if (!id) return;
      const tr = link.closest('tr');
      if (tr && !tr.querySelector('.video-card-checkbox')) {
        tr.dataset.videoId = id;
        const td = document.createElement('td');
        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.className = 'video-card-checkbox';
        cb.dataset.id = id;
        td.appendChild(cb);
        tr.prepend(td);
      }
    });
    // Add header cell for table
    const thead = document.querySelector('.video-table thead tr');
    if (thead && !thead.querySelector('.bulk-th')) {
      const th = document.createElement('th');
      th.className = 'bulk-th';
      th.style.width = '30px';
      thead.prepend(th);
    }
  }

  function exitBulkMode() {
    bulkMode = false;
    selected.clear();
    document.body.classList.remove('bulk-mode');
    toggleBtn.textContent = 'Sélectionner';
    document.querySelectorAll('.video-card-checkbox').forEach(cb => cb.remove());
    document.querySelectorAll('.bulk-th').forEach(el => el.remove());
    // Remove extra td from table rows
    document.querySelectorAll('.video-table tbody tr').forEach(tr => {
      const first = tr.firstElementChild;
      if (first && first.querySelector('.video-card-checkbox')) first.remove();
    });
    updateCount();
  }

  toggleBtn.addEventListener('click', () => {
    if (bulkMode) exitBulkMode(); else enterBulkMode();
  });

  document.getElementById('bulk-cancel').addEventListener('click', exitBulkMode);

  // Intercept clicks in bulk mode
  document.addEventListener('click', (e) => {
    if (!bulkMode) return;
    const card = e.target.closest('.video-card:not(.folder-card)');
    const row = e.target.closest('.video-table tbody tr');
    const target = card || row;
    if (!target) return;

    const id = target.dataset.videoId;
    if (!id) return;

    // Don't navigate
    if (card) e.preventDefault();

    const cb = target.querySelector('.video-card-checkbox');
    if (selected.has(id)) {
      selected.delete(id);
      if (cb) cb.checked = false;
    } else {
      selected.add(id);
      if (cb) cb.checked = true;
    }
    updateCount();
  }, true);

  // Bulk tag
  document.getElementById('bulk-tag-btn').addEventListener('click', async () => {
    if (selected.size === 0) return;
    const tagName = prompt('Nom du tag :');
    if (!tagName) return;
    try {
      const resp = await fetch('/videos/bulk/tag', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoIds: Array.from(selected), tagName })
      });
      const data = await resp.json();
      if (data.ok) { alert(data.count + ' vidéo(s) taguée(s)'); exitBulkMode(); }
      else alert('Erreur: ' + (data.error || 'inconnue'));
    } catch { alert('Erreur réseau'); }
  });

  // Bulk playlist
  document.getElementById('bulk-playlist-btn').addEventListener('click', async () => {
    if (selected.size === 0) return;
    // Fetch playlists
    try {
      const resp = await fetch('/playlists/api/list');
      const playlists = await resp.json();
      if (playlists.length === 0) { alert('Aucune playlist. Créez-en une d\'abord.'); return; }
      const choices = playlists.map((p, i) => (i + 1) + '. ' + p.name).join('\n');
      const choice = prompt('Choisir une playlist :\n' + choices);
      if (!choice) return;
      const idx = parseInt(choice) - 1;
      if (isNaN(idx) || idx < 0 || idx >= playlists.length) { alert('Choix invalide'); return; }
      const resp2 = await fetch('/videos/bulk/playlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ videoIds: Array.from(selected), playlistId: playlists[idx].id })
      });
      const data = await resp2.json();
      if (data.ok) { alert(data.count + ' vidéo(s) ajoutée(s)'); exitBulkMode(); }
      else alert('Erreur: ' + (data.error || 'inconnue'));
    } catch { alert('Erreur réseau'); }
  });

  // Bulk delete
  const delBtn = document.getElementById('bulk-delete-btn');
  if (delBtn) {
    delBtn.addEventListener('click', async () => {
      if (selected.size === 0) return;
      if (!confirm('Supprimer ' + selected.size + ' vidéo(s) de la base ? (les fichiers ne sont pas supprimés)')) return;
      try {
        const resp = await fetch('/videos/bulk/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ videoIds: Array.from(selected) })
        });
        const data = await resp.json();
        if (data.ok) { location.reload(); }
        else alert('Erreur: ' + (data.error || 'inconnue'));
      } catch { alert('Erreur réseau'); }
    });
  }
})();
</script>

<%- include('partials/footer') %>
