<%- include('partials/header') %>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
function formatDuration(seconds) {
  if (!seconds) return '';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
  return m + ':' + String(s).padStart(2, '0');
}
%>

<%
function formatDurationLong(seconds) {
  if (!seconds) return '0h';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  if (h > 0) return h + 'h ' + String(m).padStart(2, '0') + 'm';
  return m + 'min';
}
%>

<div class="page-header">
  <h1>Bibliothèques</h1>
</div>

<% if (stats.totalVideos > 0) { %>
<div class="dashboard-stats">
  <div class="stat-card">
    <span class="stat-value"><%= stats.totalVideos %></span>
    <span class="stat-label">vidéos</span>
  </div>
  <div class="stat-card">
    <span class="stat-value"><%= formatSize(stats.totalSize) %></span>
    <span class="stat-label">espace total</span>
  </div>
  <div class="stat-card">
    <span class="stat-value"><%= formatDurationLong(stats.totalDuration) %></span>
    <span class="stat-label">durée totale</span>
  </div>
</div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<!-- Continue watching -->
<% if (continueWatching.length > 0) { %>
  <div class="dashboard-section">
    <h2 class="section-title">Continuer à regarder</h2>
    <div class="video-grid">
      <% for (const v of continueWatching) { %>
        <a href="/videos/<%= v.id %>" class="video-card">
          <div class="video-card-preview">
            <% if (v.thumb) { %>
              <img src="/videos/<%= v.id %>/thumb" alt="" loading="lazy" decoding="async">
            <% } %>
            <% if (v.duration) { %>
              <span class="video-card-duration"><%= formatDuration(v.duration) %></span>
            <% } %>
            <div class="video-progress-bar">
              <div class="video-progress-fill" style="width: <%= Math.round((v.progress / v.duration) * 100) %>%"></div>
            </div>
          </div>
          <div class="video-card-info">
            <span class="video-card-title"><%= v.title || v.filename %></span>
            <span class="video-card-meta"><%= formatSize(v.size) %></span>
          </div>
        </a>
      <% } %>
    </div>
  </div>
<% } %>

<!-- Recent history -->
