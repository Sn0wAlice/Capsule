<%- include('partials/header') %>

<div class="page-header">
  <h1>Recherche : "<%= query %>"</h1>
  <p class="text-muted"><%= videos.length %> résultat(s)</p>
</div>

<% if (videos.length > 0) { %>
  <div class="search-list">
    <% for (const video of videos) { %>
      <a href="/videos/<%= video.id %>" class="search-item">
        <div class="search-item-preview">
          <% if (video.thumb) { %>
            <img src="/videos/<%= video.id %>/thumb" alt="" loading="lazy">
          <% } %>
        </div>
        <div class="search-item-info">
          <span class="search-item-title"><%= video.title || video.filename %></span>
          <span class="search-item-meta"><%= video.library_name %> &mdash; <%= video.filepath %></span>
          <span class="search-item-meta"><%= formatSize(video.size) %></span>
        </div>
      </a>
    <% } %>
  </div>
<% } else { %>
  <div class="empty-state">
    <p>Aucune vidéo trouvée pour "<%= query %>".</p>
  </div>
<% } %>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
%>

<%- include('partials/footer') %>
