<%- include('partials/header') %>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
%>

<div class="page-header">
  <h1>Doublons</h1>
</div>

<% if (groups.length === 0) { %>
  <div class="empty-state">
    <p>Aucun doublon détecté. Vos bibliothèques sont propres !</p>
  </div>
<% } else { %>
  <p class="text-muted" style="margin-bottom: 1.5rem">
    <%= groups.length %> groupe(s) de fichiers identiques détecté(s) (même nom + même taille).
  </p>

  <% for (const group of groups) { %>
    <div class="card duplicate-group">
      <h2><%= group.filename %> — <%= formatSize(group.size) %></h2>
      <div class="duplicate-list">
        <% for (const v of group.videos) { %>
          <div class="duplicate-item">
            <div class="duplicate-thumb">
              <% if (v.thumb) { %>
                <img src="/videos/<%= v.id %>/thumb" alt="" loading="lazy">
              <% } %>
            </div>
            <div class="duplicate-info">
              <a href="/videos/<%= v.id %>" class="duplicate-title"><%= v.title || v.filename %></a>
              <span class="duplicate-meta">
                <span class="duplicate-lib"><%= v.library_name %></span>
                <span class="duplicate-path"><%= v.filepath %></span>
              </span>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>
<% } %>

<%- include('partials/footer') %>
