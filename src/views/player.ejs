<%- include('partials/header') %>

<%
function formatSize(bytes) {
  if (!bytes) return '—';
  const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
  let i = 0;
  let size = bytes;
  while (size >= 1024 && i < units.length - 1) { size /= 1024; i++; }
  return size.toFixed(i > 0 ? 1 : 0) + ' ' + units[i];
}
function formatDuration(seconds) {
  if (!seconds) return '—';
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  if (h > 0) return h + 'h ' + String(m).padStart(2, '0') + 'm ' + String(s).padStart(2, '0') + 's';
  return m + 'm ' + String(s).padStart(2, '0') + 's';
}
function formatBitrate(bps) {
  if (!bps) return '—';
  if (bps >= 1000000) return (bps / 1000000).toFixed(1) + ' Mbps';
  return (bps / 1000).toFixed(0) + ' kbps';
}
%>

<div class="player-page">
  <!-- Breadcrumb -->
  <div class="player-breadcrumb">
    <a href="/dashboard">Bibliothèques</a>
    <span class="separator">/</span>
    <a href="/libraries/<%= video.library_id %>"><%= video.library_name %></a>
    <% for (const crumb of breadcrumb) { %>
      <span class="separator">/</span>
      <a href="/libraries/<%= video.library_id %>?view=folder&path=<%= encodeURIComponent(crumb.path) %>"><%= crumb.name %></a>
    <% } %>
    <span class="separator">/</span>
    <span class="current"><%= video.filename %></span>
  </div>

  <div class="player-layout">
    <!-- Left: Video Player -->
    <div class="player-main">
      <div class="player-container">
        <div id="artplayer-app"></div>
      </div>
      <div class="player-title-bar">
        <h1 class="player-title" id="video-title"<% if (['owner','admin','write'].includes(permission)) { %> title="Double-cliquer pour renommer"<% } %>><%= video.title || video.filename %></h1>
        <div class="player-actions">
          <button class="btn btn-sm btn-fav<%= isFavorite ? ' active' : '' %>" id="btn-fav" title="Favoris (F)">
            <span id="fav-icon"><%- isFavorite ? '&#9733;' : '&#9734;' %></span>
          </button>
          <button class="btn btn-sm btn-wl<%= isWatchlisted ? ' active' : '' %>" id="btn-wl" title="A regarder (W)">
            <span id="wl-icon"><%- isWatchlisted ? '&#10003;' : '&#9201;' %></span>
          </button>
          <% if (playlists.length > 0) { %>
          <select id="add-to-playlist" class="autoplay-select" title="Ajouter à une playlist">
            <option value="">+ Playlist</option>
            <% for (const pl of playlists) { %>
              <option value="<%= pl.id %>"><%= pl.name %></option>
            <% } %>
          </select>
          <% } %>
          <div class="autoplay-control">
            <span class="autoplay-label">Auto</span>
            <select id="autoplay-mode" class="autoplay-select">
              <option value="off">Off</option>
              <option value="random">Random</option>
              <option value="alpha">A-Z</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Tags -->
      <div class="tags-bar">
        <div class="tags-list" id="tags-list">
          <% for (const tag of tags) { %>
            <span class="tag tag-<%= tag.color %>" data-id="<%= tag.id %>">
              <%= tag.name %>
              <% if (['owner','admin','write'].includes(permission)) { %>
                <button class="tag-remove" data-id="<%= tag.id %>">&times;</button>
              <% } %>
            </span>
          <% } %>
        </div>
        <% if (['owner','admin','write'].includes(permission)) { %>
        <form class="tag-add-form" id="tag-form">
          <input type="text" id="tag-input" placeholder="+ tag" autocomplete="off">
        </form>
        <% } %>
      </div>
    </div>

    <!-- Right: Info Panel -->
    <div class="player-sidebar">
      <div class="sidebar-section">
        <h3>Informations</h3>
        <div class="info-row">
          <span class="info-label">Fichier</span>
          <span class="info-value"><%= video.filename %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Chemin</span>
          <span class="info-value mono"><%= video.filepath %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Bibliothèque</span>
          <span class="info-value"><%= video.library_name %></span>
        </div>
        <% if (video.duration) { %>
        <div class="info-row">
          <span class="info-label">Durée</span>
          <span class="info-value"><%= formatDuration(video.duration) %></span>
        </div>
        <% } %>
        <% if (video.size) { %>
        <div class="info-row">
          <span class="info-label">Taille</span>
          <span class="info-value"><%= formatSize(video.size) %></span>
        </div>
        <% } %>
        <% if (video.width && video.height) { %>
        <div class="info-row">
          <span class="info-label">Résolution</span>
          <span class="info-value"><%= video.width %>×<%= video.height %></span>
        </div>
        <% } %>
        <% if (video.codec) { %>
        <div class="info-row">
          <span class="info-label">Codec vidéo</span>
          <span class="info-value mono"><%= video.codec %></span>
        </div>
        <% } %>
        <% if (video.audio_codec) { %>
        <div class="info-row">
          <span class="info-label">Codec audio</span>
          <span class="info-value mono"><%= video.audio_codec %></span>
        </div>
        <% } %>
        <%
          let audioTracks = null;
          try {
            audioTracks = video.audio_tracks ? (typeof video.audio_tracks === 'string' ? JSON.parse(video.audio_tracks) : video.audio_tracks) : null;
          } catch(e) {}
        %>
        <% if (audioTracks && audioTracks.length > 1) { %>
        <div class="info-row">
          <span class="info-label">Pistes audio</span>
          <span class="info-value">
            <% for (const track of audioTracks) { %>
              <span class="badge badge-info" style="margin: 1px 2px; display: inline-block;">
                <%= track.language || ('Piste ' + track.index) %><% if (track.title) { %> — <%= track.title %><% } %> (<%= track.codec %>)
              </span>
            <% } %>
          </span>
        </div>
        <% } %>
        <% if (video.bitrate) { %>
        <div class="info-row">
          <span class="info-label">Débit</span>
          <span class="info-value"><%= formatBitrate(video.bitrate) %></span>
        </div>
        <% } %>
        <% if (video.mime_type) { %>
        <div class="info-row">
          <span class="info-label">Type</span>
          <span class="info-value mono"><%= video.mime_type %></span>
        </div>
        <% } %>
        <div class="info-row">
          <span class="info-label">Ajouté le</span>
          <span class="info-value"><%= new Date(video.created_at).toLocaleDateString('fr-FR') %></span>
        </div>
      </div>

      <div class="sidebar-section sidebar-shortcuts">
        <h3>Raccourcis</h3>
        <div class="shortcut-row"><kbd>F</kbd> <span>Favoris</span></div>
        <div class="shortcut-row"><kbd>W</kbd> <span>A regarder</span></div>
        <div class="shortcut-row"><kbd>N</kbd> <span>Vidéo suivante</span></div>
        <div class="shortcut-row"><kbd>L</kbd> <span>Plein écran</span></div>
        <div class="shortcut-row"><kbd>M</kbd> <span>Mode auto-play</span></div>
        <% if (['owner','admin','write'].includes(permission)) { %>
        <div class="shortcut-row"><kbd>T</kbd> <span>Ajouter un tag</span></div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Similar Videos -->
  <% if (similar.length > 0) { %>
  <div class="similar-section">
    <h2>Autres vidéos</h2>
    <div class="video-grid">
      <% for (const v of similar) { %>
        <a href="/videos/<%= v.id %>" class="video-card">
          <div class="video-card-preview">
            <% if (v.thumb) { %>
              <img src="/videos/<%= v.id %>/thumb" alt="" loading="lazy">
            <% } %>
          </div>
          <div class="video-card-info">
            <span class="video-card-title"><%= v.title || v.filename %></span>
            <span class="video-card-meta"><%= formatSize(v.size) %></span>
          </div>
        </a>
      <% } %>
    </div>
  </div>
  <% } %>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/artplayer@5.2.1/dist/artplayer.css">
<script src="https://cdn.jsdelivr.net/npm/artplayer@5.2.1/dist/artplayer.js"></script>
<script>
  const VIDEO_ID = <%= video.id %>;
  const SAVED_PROGRESS = <%= savedProgress %>;
  const CAN_WRITE = <%= ['owner','admin','write'].includes(permission) %>;

  // Restore autoplay mode from localStorage
  const autoplaySelect = document.getElementById('autoplay-mode');
  const savedMode = localStorage.getItem('capsule_autoplay') || 'off';
  autoplaySelect.value = savedMode;
  autoplaySelect.addEventListener('change', () => {
    localStorage.setItem('capsule_autoplay', autoplaySelect.value);
  });

  // Restore saved playback rate
  const savedRate = parseFloat(localStorage.getItem('capsule_playback_rate')) || 1;

  // Init ArtPlayer
  const art = new Artplayer({
    container: '#artplayer-app',
    url: '/videos/' + VIDEO_ID + '/stream',
    type: '<%= video.mime_type === "video/x-matroska" ? "mkv" : "" %>',
    volume: 0.7,
    autoSize: false,
    autoMini: true,
    loop: false,
    flip: true,
    playbackRate: true,
    aspectRatio: true,
    setting: true,
    hotkey: true,
    pip: true,
    mutex: true,
    fullscreen: true,
    fullscreenWeb: true,
    miniProgressBar: true,
    playsInline: true,
    theme: '#8b5cf6',
    controls: [
      {
        position: 'right',
        html: '<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/><rect x="4" y="5" width="2" height="14" rx="1"/></svg>',
        tooltip: 'Vidéo suivante (N)',
        click: function () {
          goNext();
        },
      },
    ],
  });

  // Resize container to match video aspect ratio
  art.on('video:loadedmetadata', () => {
    const { videoWidth, videoHeight } = art.video;
    if (videoWidth && videoHeight) {
      const container = document.getElementById('artplayer-app');
      const w = container.clientWidth;
      const h = Math.min(w * videoHeight / videoWidth, window.innerHeight * 0.8);
      container.style.height = h + 'px';
      art.autoSize = false;
    }
  });

  // Resume playback + auto-start if navigated via autoplay
  const urlParams = new URLSearchParams(window.location.search);
  const shouldAutoplay = urlParams.get('autoplay') === '1';

  art.on('ready', () => {
    // Restore playback rate
    if (savedRate !== 1) art.playbackRate = savedRate;
    if (SAVED_PROGRESS > 2) {
      art.currentTime = SAVED_PROGRESS;
    }
    if (shouldAutoplay) {
      // Wait for the seek to settle before playing
      const tryPlay = () => {
        const p = art.play();
        if (p && typeof p.catch === 'function') {
          p.catch(() => {
            // Browser blocked autoplay — try muted
            art.muted = true;
            art.play().catch(() => {});
          });
        }
      };
      if (SAVED_PROGRESS > 2) {
        art.once('video:canplay', tryPlay);
      } else {
        tryPlay();
      }
    }
  });

  // Save progress every 5 seconds
  let lastSaved = 0;
  art.on('video:timeupdate', () => {
    const now = Date.now();
    if (now - lastSaved > 5000) {
      lastSaved = now;
      fetch('/videos/' + VIDEO_ID + '/progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ progress: art.currentTime }),
      }).catch(() => {});
    }
  });

  // Save on pause/close
  function saveProgress() {
    if (art.currentTime > 0) {
      navigator.sendBeacon(
        '/videos/' + VIDEO_ID + '/progress',
        new Blob([JSON.stringify({ progress: art.currentTime })], { type: 'application/json' })
      );
    }
  }
  art.on('video:pause', saveProgress);
  window.addEventListener('beforeunload', saveProgress);

  // Persist playback rate changes
  art.on('video:ratechange', () => {
    localStorage.setItem('capsule_playback_rate', art.playbackRate);
  });

  // Auto-play next on video end
  art.on('video:ended', () => {
    const mode = autoplaySelect.value;
    if (mode === 'off') return;
    fetch('/videos/' + VIDEO_ID + '/next?mode=' + mode)
      .then(r => r.json())
      .then(data => {
        if (data.id) window.location.href = '/videos/' + data.id + '?autoplay=1';
      })
      .catch(() => {});
  });

  // Go to next video
  function goNext() {
    const mode = autoplaySelect.value === 'off' ? 'random' : autoplaySelect.value;
    fetch('/videos/' + VIDEO_ID + '/next?mode=' + mode)
      .then(r => r.json())
      .then(data => {
        if (data.id) window.location.href = '/videos/' + data.id + '?autoplay=1';
      })
      .catch(() => {});
  }

  // Toggle favorite
  const btnFav = document.getElementById('btn-fav');
  const favIcon = document.getElementById('fav-icon');
  function toggleFav() {
    fetch('/videos/' + VIDEO_ID + '/favorite', { method: 'POST' })
      .then(r => r.json())
      .then(data => {
        favIcon.innerHTML = data.favorited ? '&#9733;' : '&#9734;';
        btnFav.classList.toggle('active', data.favorited);
      })
      .catch(() => {});
  }
  btnFav.addEventListener('click', toggleFav);

  // Toggle watchlist
  const btnWl = document.getElementById('btn-wl');
  const wlIcon = document.getElementById('wl-icon');
  function toggleWl() {
    fetch('/videos/' + VIDEO_ID + '/watchlist', { method: 'POST' })
      .then(r => r.json())
      .then(data => {
        wlIcon.innerHTML = data.watchlisted ? '&#10003;' : '&#9201;';
        btnWl.classList.toggle('active', data.watchlisted);
      })
      .catch(() => {});
  }
  btnWl.addEventListener('click', toggleWl);

  // Cycle autoplay mode
  function cycleAutoplay() {
    const modes = ['off', 'random', 'alpha'];
    const idx = modes.indexOf(autoplaySelect.value);
    autoplaySelect.value = modes[(idx + 1) % modes.length];
    localStorage.setItem('capsule_autoplay', autoplaySelect.value);
  }

  // Inline rename (double-click title)
  const titleEl = document.getElementById('video-title');
  if (CAN_WRITE) titleEl.addEventListener('dblclick', () => {
    const current = titleEl.textContent.trim();
    const input = document.createElement('input');
    input.type = 'text';
    input.value = current;
    input.className = 'rename-input';
    titleEl.replaceWith(input);
    input.focus();
    input.select();

    function save() {
      const newTitle = input.value.trim();
      fetch('/videos/' + VIDEO_ID + '/rename', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: newTitle }),
      }).then(r => r.json()).then(data => {
        titleEl.textContent = data.title || '<%= video.filename.replace(/'/g, "\\'") %>';
        input.replaceWith(titleEl);
      }).catch(() => {
        titleEl.textContent = current;
        input.replaceWith(titleEl);
      });
    }
    input.addEventListener('blur', save);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
      if (e.key === 'Escape') { titleEl.textContent = current; input.replaceWith(titleEl); }
    });
  });

  // Tags
  const tagsList = document.getElementById('tags-list');
  const tagForm = document.getElementById('tag-form');
  const tagInput = document.getElementById('tag-input');

  if (CAN_WRITE && tagForm) tagForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = tagInput.value.trim();
    if (!name) return;
    fetch('/videos/' + VIDEO_ID + '/tags', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name }),
    }).then(r => r.json()).then(data => {
      if (data.tag) {
        const span = document.createElement('span');
        span.className = 'tag tag-' + data.tag.color.replace(/[^a-z]/g, '');
        span.dataset.id = data.tag.id;
        span.textContent = data.tag.name + ' ';
        const btn = document.createElement('button');
        btn.className = 'tag-remove';
        btn.dataset.id = data.tag.id;
        btn.textContent = '\u00d7';
        span.appendChild(btn);
        tagsList.appendChild(span);
        tagInput.value = '';
      }
    }).catch(() => {});
  });

  if (CAN_WRITE) tagsList.addEventListener('click', (e) => {
    if (e.target.classList.contains('tag-remove')) {
      const tagId = e.target.dataset.id;
      fetch('/videos/' + VIDEO_ID + '/tags/' + tagId, { method: 'DELETE' })
        .then(r => r.json())
        .then(() => {
          e.target.parentElement.remove();
        })
        .catch(() => {});
    }
  });

  // Add to playlist
  const playlistSelect = document.getElementById('add-to-playlist');
  if (playlistSelect) {
    playlistSelect.addEventListener('change', () => {
      const plId = playlistSelect.value;
      if (!plId) return;
      fetch('/playlists/' + plId + '/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ video_id: VIDEO_ID }),
      }).then(r => r.json()).then(() => {
        playlistSelect.value = '';
      }).catch(() => {});
    });
  }

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT' || e.target.tagName === 'TEXTAREA') return;
    switch (e.key.toLowerCase()) {
      case 'f': e.preventDefault(); toggleFav(); break;
      case 'w': e.preventDefault(); toggleWl(); break;
      case 'n': e.preventDefault(); goNext(); break;
      case 'm': e.preventDefault(); cycleAutoplay(); break;
      case 'l': e.preventDefault(); art.fullscreen = !art.fullscreen; break;
      case 't': if (CAN_WRITE && tagInput) { e.preventDefault(); tagInput.focus(); } break;
    }
  });
</script>

<%- include('partials/footer') %>
