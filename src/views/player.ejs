<%- include('partials/header') %>

<div class="player-page">
  <div class="player-header">
    <a href="/libraries/<%= video.library_id %>" class="btn btn-sm">&larr; Retour</a>
    <h2><%= video.title || video.filename %></h2>
  </div>

  <div class="player-container">
    <div id="artplayer-app"></div>
  </div>

  <div class="video-details card">
    <p><strong>Fichier :</strong> <%= video.filename %></p>
    <p><strong>Chemin :</strong> <%= video.filepath %></p>
    <p><strong>Bibliothèque :</strong> <%= video.library_name %></p>
    <% if (video.size) { %>
      <p><strong>Taille :</strong> <%
        const bytes = video.size;
        const units = ['o', 'Ko', 'Mo', 'Go', 'To'];
        let i = 0; let s = bytes;
        while (s >= 1024 && i < units.length - 1) { s /= 1024; i++; }
      %><%= s.toFixed(i > 0 ? 1 : 0) + ' ' + units[i] %></p>
    <% } %>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/artplayer@5.2.1/dist/artplayer.css">
<script src="https://cdn.jsdelivr.net/npm/artplayer@5.2.1/dist/artplayer.js"></script>
<script>
  const art = new Artplayer({
    container: '#artplayer-app',
    url: '/videos/<%= video.id %>/stream',
    type: '<%= video.mime_type === "video/x-matroska" ? "mkv" : "" %>',
    volume: 0.7,
    autoSize: true,
    autoMini: true,
    loop: false,
    flip: true,
    playbackRate: true,
    aspectRatio: true,
    setting: true,
    hotkey: true,
    pip: true,
    mutex: true,
    fullscreen: true,
    fullscreenWeb: true,
    miniProgressBar: true,
    playsInline: true,
    theme: '#8b5cf6',
  });
</script>

<%- include('partials/footer') %>
